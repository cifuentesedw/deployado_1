option_settings:
  # ── WSGI ──────────────────────────────────────────────────────────────────
  aws:elasticbeanstalk:container:python:
    WSGIPath: application:application
 
  # ── Archivos estáticos servidos directamente por Nginx ────────────────────
  # Para esta REST API no hay archivos estáticos, pero se conserva la
  # configuración original por consistencia con la Entrega 1
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: static
 
  # ── Health check — AGREGADO para eliminar los WARN HTTP 4xx ──────────────
  # EB hace GET / por defecto; como / retorna 404 (no existe en la API),
  # EB interpreta que el entorno está degradado. Apuntando a /health
  # (que siempre retorna 200) se elimina ese falso positivo.
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health
 
  # ── Variables de entorno ──────────────────────────────────────────────────
  aws:elasticbeanstalk:application:environment:
    FLASK_ENV: production
    FLASK_DEBUG: "false"
 